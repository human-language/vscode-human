{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Human",
  "scopeName": "source.hmn",
  "patterns": [
    { "include": "#comment" },
    { "include": "#import" },
    { "include": "#agent" },
    { "include": "#system" },
    { "include": "#constraints-block" },
    { "include": "#constraint-line" },
    { "include": "#flow-block" },
    { "include": "#test-block" },
    { "include": "#test-input" },
    { "include": "#test-expect" },
    { "include": "#property" }
  ],
  "repository": {
    "comment": {
      "match": "(#)(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.comment.hmn" },
        "2": { "name": "comment.line.number-sign.hmn" }
      }
    },
    "import": {
      "patterns": [
        {
          "match": "^\\s*(IMPORT)\\s+(\\.\\.?\\/[^\\s]+)",
          "captures": {
            "1": { "name": "keyword.control.import.hmn" },
            "2": { "name": "string.other.path.hmn" }
          }
        },
        {
          "match": "^\\s*(IMPORT)\\s+(.+)",
          "captures": {
            "1": { "name": "keyword.control.import.hmn" },
            "2": { "name": "entity.name.tag.package.hmn" }
          }
        }
      ]
    },
    "agent": {
      "match": "^\\s*(AGENT)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.agent.hmn" },
        "2": { "name": "entity.name.type.agent.hmn" }
      }
    },
    "system": {
      "match": "^\\s*(SYSTEM)\\s+(\\.\\.?\\/[^\\s]+)",
      "captures": {
        "1": { "name": "keyword.control.system.hmn" },
        "2": { "name": "string.other.path.hmn" }
      }
    },
    "constraints-block": {
      "match": "^\\s*(CONSTRAINTS)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.constraints.hmn" },
        "2": { "name": "entity.name.type.constraints.hmn" }
      }
    },
    "constraint-line": {
      "match": "^\\s*(NEVER|MUST|SHOULD|AVOID|MAY)\\b(.*)$",
      "captures": {
        "1": { "name": "keyword.other.constraint-level.hmn" },
        "2": { "name": "string.unquoted.constraint-text.hmn" }
      }
    },
    "flow-block": {
      "match": "^\\s*(FLOW)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.flow.hmn" },
        "2": { "name": "entity.name.type.flow.hmn" }
      }
    },
    "test-block": {
      "match": "^\\s*(TEST)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.test.hmn" }
      }
    },
    "test-input": {
      "match": "^\\s*(INPUT)\\s+(\"(?:[^\"\\\\]|\\\\[\"\\\\])*\")",
      "captures": {
        "1": { "name": "keyword.control.input.hmn" },
        "2": { "name": "string.quoted.double.hmn" }
      }
    },
    "test-expect": {
      "match": "^\\s*(EXPECT)\\s+(NOT\\s+)?(CONTAINS|MATCHES)\\s+(\"(?:[^\"\\\\]|\\\\[\"\\\\])*\")",
      "captures": {
        "1": { "name": "keyword.control.expect.hmn" },
        "2": { "name": "keyword.control.not.hmn" },
        "3": { "name": "keyword.control.operator.hmn" },
        "4": { "name": "string.quoted.double.hmn" }
      }
    },
    "property": {
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(.+)",
      "captures": {
        "1": { "name": "variable.other.property.hmn" },
        "2": { "name": "keyword.operator.assignment.hmn" },
        "3": {
          "patterns": [
            { "include": "#value" }
          ]
        }
      }
    },
    "value": {
      "patterns": [
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#path" }
      ]
    },
    "string": {
      "match": "\"(?:[^\"\\\\]|\\\\[\"\\\\])*\"",
      "name": "string.quoted.double.hmn"
    },
    "number": {
      "match": "-?[0-9]+(\\.[0-9]+)?",
      "name": "constant.numeric.hmn"
    },
    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.hmn"
    },
    "path": {
      "match": "\\.\\.?\\/[^\\s]+",
      "name": "string.other.path.hmn"
    }
  }
}
